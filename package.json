{
  "name": "@api-doctor/cli",
  "version": "0.0.2",
  "description": "Deterministic verification rules for AI-generated API integrations",
  "keywords": [
    "api",
    "lint",
    "oxlint",
    "resend",
    "supabase",
    "ai",
    "claude",
    "cursor",
    "codex",
    "integration"
  ],
  "type": "module",
  "private": false,
  "license": "MIT",
  "bin": {
    "api-doctor": "./dist/cli.mjs"
  },
  "main": "./dist/cli.cjs",
  "module": "./dist/cli.mjs",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.mjs",
      "require": "./dist/cli.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qualtyco/api-doctor.git"
  },
  "homepage": "https://github.com/qualtyco/api-doctor",
  "bugs": {
    "url": "https://github.com/qualtyco/api-doctor/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.13.10",
    "oxlint": "^1.68.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
